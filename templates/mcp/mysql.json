{
  "mcpServers": {
    "mysql": {
      "command": "npx",
      "args": ["-y", "@benborla29/mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "여기에_DB_호스트_IP_입력",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "여기에_아이디_입력",
        "MYSQL_PASS": "여기에_비밀번호_입력",
        "MYSQL_DB": "여기에_DB명_입력",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    }
  }
}
