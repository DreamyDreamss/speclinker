{
  "mcpServers": {
    "mssql": {
      "command": "npx",
      "args": ["-y", "@azure/mcp-server-mssql"],
      "env": {
        "MSSQL_HOST": "여기에_DB_호스트_IP_입력",
        "MSSQL_PORT": "1433",
        "MSSQL_DATABASE": "여기에_DB명_입력",
        "MSSQL_USER": "여기에_아이디_입력",
        "MSSQL_PASSWORD": "여기에_비밀번호_입력",
        "MSSQL_ENCRYPT": "false"
      }
    }
  }
}
