{
  "name": "speclinker",
  "version": "2.4.0",
  "description": "SI/ITO SDD 전주기 자동화 + UA 코드 분석 통합 — 산출물↔소스 REQ-ID 체이닝 대시보드",
  "author": "gen-harness",
  "skills": [
    "skills/sl-init",
    "skills/sl-genesis",
    "skills/sl-recon",
    "skills/sl-aidd",
    "skills/sl-dev",
    "skills/sl-test",
    "skills/sl-rtm",
    "skills/sl-analyze",
    "skills/sl-change",
    "ua/skills/understand",
    "ua/skills/understand-domain",
    "ua/skills/understand-diff",
    "ua/skills/understand-dashboard"
  ],
  "agents": [
    "agents/spec-agent.md",
    "agents/rd-agent.md",
    "agents/srs-agent.md",
    "agents/sad-agent.md",
    "agents/ddd-api-agent.md",
    "agents/ddd-db-agent.md",
    "agents/ddd-ui-agent.md",
    "agents/rtm-agent.md",
    "agents/dev-agent.md",
    "agents/test-agent.md",
    "ua/agents/architecture-analyzer.md",
    "ua/agents/domain-analyzer.md",
    "ua/agents/file-analyzer.md",
    "ua/agents/project-scanner.md"
  ],
  "templates": "templates/",
  "scripts": {
    "dashboard": "node scripts/run-dashboard.js",
    "build": "node -e \"process.chdir(require('path').join(__dirname,'ua')); require('child_process').execSync('pnpm --filter @understand-anything/core build', {stdio:'inherit'})\"",
    "bridge": "node scripts/ua_req_bridge.js",
    "graph-finalize": "node scripts/ua_req_bridge.js",
    "scan": "node scripts/run-scan.js"
  },
  "envVars": {
    "SPECLINKER_MODE": "auto",
    "SPECLINKER_NETWORK": "auto",
    "GRAPH_DIR": "."
  }
}
